# お客様情報・査定結果の自動転送先を設定します。
# このファイルを secrets.toml にコピーし、値を設定してください。
# Streamlit Cloud の場合はダッシュボードの「Secrets」で設定してください。

# Webhook URL（必須）: 査定完了時にPOSTでJSONデータを送信します。
# 例: Zapier, Make, n8n, Slack Incoming Webhook, 自社API などのURL
# 実際の値は secrets.toml に記載（このファイルはGitにコミットしないこと）
# WEBHOOK_URL = "https://chat.googleapis.com/v1/spaces/XXXXX/messages?key=XXX&token=XXX"
